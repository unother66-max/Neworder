generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Track {
  id        String   @id @default(cuid())
  keyword   String
  placeUrl  String
  createdAt DateTime @default(now())
  records   Record[]
}

model Record {
  id        String   @id @default(cuid())
  rank      Int
  createdAt DateTime @default(now())
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id])
}

model Place {
  id          String         @id @default(cuid())
  userId      String
  name        String
  category    String?
  address     String?
  placeUrl    String?
  imageUrl    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  keywords    PlaceKeyword[]
  rankHistory RankHistory[]
}

model PlaceKeyword {
  id           String   @id @default(cuid())
  placeId      String
  keyword      String
  mobileVolume Int?
  pcVolume     Int?
  totalVolume  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isTracking   Boolean  @default(false)

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, keyword])
}

model RankHistory {
  id        String   @id @default(cuid())
  placeId   String
  keyword   String
  rank      Int
  createdAt DateTime @default(now())

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
}