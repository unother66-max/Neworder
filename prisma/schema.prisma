generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id     String  @id @default(cuid())
  email  String  @unique
  name   String?
  places Place[]
}

model Track {
  id        String   @id @default(cuid())
  keyword   String
  placeUrl  String
  createdAt DateTime @default(now())
  records   Record[]
}

model Record {
  id        String   @id @default(cuid())
  rank      Int
  createdAt DateTime @default(now())
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id])
}

model Place {
  id                 String               @id @default(cuid())
  userId             String
  name               String
  category           String?
  address            String?
  jibunAddress       String?
  x                  String?
  y                  String?
  placeUrl           String?
  imageUrl           String?
  reviewAutoTracking Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords      PlaceKeyword[]
  rankHistory   RankHistory[]
  reviewHistory PlaceReviewHistory[]

  @@index([userId])
}

model PlaceKeyword {
  id           String   @id @default(cuid())
  placeId      String
  keyword      String
  mobileVolume Int?
  pcVolume     Int?
  totalVolume  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isTracking   Boolean  @default(false)
  place        Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, keyword])
  @@index([placeId])
}

model RankHistory {
  id        String   @id @default(cuid())
  placeId   String
  keyword   String
  rank      Int
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model PlaceReviewHistory {
  id                 String   @id @default(cuid())
  placeId            String
  totalReviewCount   Int
  visitorReviewCount Int
  blogReviewCount    Int
  saveCount          String
  keywords           String[]
  createdAt          DateTime @default(now())

  place              Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}