generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 공통 설정 ---
enum SmartstoreSpace {
  NAVER_PRICE
  PLUS_STORE
  NAVER_REVIEW
}

enum UserTier {
  FREE
  PRO
}

// --- 🚨 사용자 모델 (인증 및 관계 설정) ---
model User {
  id                      String                   @id @default(cuid())
  email                   String?                  @unique
  name                    String?
  image                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  /** false: 마이그레이션으로 createdAt만 채워져 실제 가입일과 다를 수 있음 */
  createdAtReliable       Boolean                  @default(true)
  /** 관리자 전용 회원 메모 (비공개) */
  adminMemo               String?                  @db.Text
  tier                    UserTier                 @default(FREE)
  emailVerified           DateTime?
  /** 로그인 세션으로 확인된 페이지 방문 시 /api/internal/visit 에서 갱신 */
  lastVisitAt             DateTime?

  // 인증 관련 연결
  accounts                Account[]
  sessions                Session[]
  
  // 기존 기능 연결 (이 모델들이 아래에 정의되어 있어야 에러가 안 납니다)
  places                  Place[]
  smartstoreProducts      SmartstoreProduct[]
  smartstoreReviewTargets SmartstoreReviewTarget[]
  posts                   Post[]
  comments                Comment[]
  visitorEvents           VisitorEvent[]
  blogAnalysisHistories BlogAnalysisHistory[]
}

// --- 🚨 인증 필수 모델 ---
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?
refresh_token_expires_in Int?


  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/** 하루 단위 방문: IP + User-Agent 해시로 같은 날 중복 제거 (날짜는 Asia/Seoul yyyy-MM-dd) */
model VisitorLog {
  id        String   @id @default(cuid())
  visitDate String
  ipHash    String   @db.VarChar(64)
  uaHash    String   @db.VarChar(64)
  seenAt    DateTime @default(now())

  @@unique([visitDate, ipHash, uaHash])
  @@index([visitDate])
}

/** 방문 건별 이벤트 (대시보드·유입·최근 로그용). 일 방문 카운트는 VisitorLog 유지 */
model VisitorEvent {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  /** Asia/Seoul yyyy-MM-dd 집계 키 */
  visitDate          String
  path               String?  @db.VarChar(512)
  /** 짧게만 저장 */
  referrer           String?  @db.VarChar(512)
  referrerCategory   String   @default("other")
  ipHash             String   @db.VarChar(64)
  uaSnippet          String?  @db.VarChar(256)
  /** 로그인 세션 있을 때만 기록 (익명 방문은 null) */
  userId             String?
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([visitDate])
  @@index([createdAt])
  @@index([referrerCategory])
  @@index([createdAt, ipHash])
  @@index([ipHash, path, createdAt])
  @@index([userId])
}

/** 관리자용 운영 알림 (수집/크론 실패 등) */
model AdminAlert {
  id        String   @id @default(cuid())
  type      String
  level     String
  title     String
  message   String   @db.Text
  meta      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([isRead])
  @@index([type])
  @@index([level])
}

// --- 🚨 기존 기능 모델 (오류 방지를 위해 모두 포함) ---

model Place {
  id                 String               @id @default(cuid())
  userId             String
  name               String
  category           String?
  address            String?
  placeUrl           String?
  imageUrl           String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  jibunAddress       String?
  reviewAutoTracking Boolean              @default(false)
  x                  String?
  y                  String?
  type               String               @default("rank")
  reviewPinned       Boolean              @default(false)
  rankPinned         Boolean              @default(false)
  rankPinnedAt       DateTime?
  kakaoAutoTracking  Boolean              @default(false)
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords           PlaceKeyword[]
  reviewHistory      PlaceReviewHistory[]
  rankHistory        RankHistory[]
  kakaoRankHistory   KakaoRankHistory[]
  placeMonthlyVolume Int?                 @default(0)
  placeMobileVolume  Int?                 @default(0)
  placePcVolume      Int?                 @default(0)

  @@index([userId])
}

model PlaceKeyword {
  id           String   @id @default(cuid())
  placeId      String
  keyword      String
  mobileVolume Int?
  pcVolume     Int?
  totalVolume  Int?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isTracking   Boolean  @default(false)
  place        Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, keyword])
  @@index([placeId])
}

model RankHistory {
  id        String   @id @default(cuid())
  placeId   String
  keyword   String
  rank      Int
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model KakaoRankHistory {
  id           String   @id @default(cuid())
  placeId      String
  keyword      String
  searchAll    Int?
  searchCat    Int?
  directionAll Int?
  directionCat Int?
  favoriteAll  Int?
  favoriteCat  Int?
  shareAll     Int?
  shareCat     Int?
  trackedAt    DateTime @default(now())
  place        Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model PlaceReviewHistory {
  id                 String   @id @default(cuid())
  placeId            String
  trackedDate        String
  totalReviewCount   Int
  visitorReviewCount Int
  blogReviewCount    Int
  saveCount          String
  keywords           String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  place              Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, trackedDate])
  @@index([placeId])
  @@index([trackedDate])
}

model SmartstoreProduct {
  id              String          @id @default(cuid())
  userId          String
  productId       String
  space           SmartstoreSpace @default(NAVER_PRICE)
  productUrl      String
  name            String
  category        String?
  /** 네이버 스토어 카탈로그 리프 카테고리 번호 — 리뷰 product-summary API에 사용 */
  leafCategoryId  Int?
  thumbnailLink   String?
  imageUrl        String?
  mallName      String?
  sellerTags    String[]        @default([])
  rankPinned    Boolean         @default(false)
  rankPinnedAt  DateTime?
  autoTracking  Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords  SmartstoreKeyword[]
  histories SmartstoreRankHistory[]

  @@unique([userId, productId, space])
  @@index([userId])
  @@index([userId, space])
}

model SmartstoreReviewTarget {
  id                    String   @id @default(cuid())
  userId                String
  productId             String
  productUrl            String
  name                  String
  imageUrl              String?
  storeName             String?
  /** 리뷰 요약 JSON API(leafCategoryId 쿼리) — 미확보 시 HTML·검색 fallback */
  leafCategoryId        Int?
  reviewCount           Int?     @default(0)
  reviewRating          Float?
  reviewPhotoVideoCount Int?     @default(0)
  reviewMonthlyUseCount Int?     @default(0)
  reviewRepurchaseCount Int?     @default(0)
  reviewStorePickCount  Int?     @default(0)
  reviewStarSummary     Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  histories     SmartstoreReviewHistory[]
  recentReviews SmartstoreRecentReview[]

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model SmartstoreReviewHistory {
  id                    String   @id @default(cuid())
  targetId              String
  trackedDate           String
  reviewCount           Int
  reviewRating          Float?
  reviewPhotoVideoCount Int?
  reviewMonthlyUseCount Int?
  reviewRepurchaseCount Int?
  reviewStorePickCount  Int?
  reviewStarSummary     Json?
  createdAt             DateTime @default(now())

  target SmartstoreReviewTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([targetId, trackedDate])
  @@index([targetId])
  @@index([trackedDate])
}

model SmartstoreRecentReview {
  id        String    @id @default(cuid())
  targetId  String
  reviewKey String
  postedAt  DateTime?
  rating    Int?
  author    String?
  content   String
  createdAt DateTime  @default(now())

  target SmartstoreReviewTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([targetId, reviewKey])
  @@index([targetId])
  @@index([createdAt])
}

model SmartstoreKeyword {
  id           String   @id @default(cuid())
  productId    String
  keyword      String
  mobileVolume Int?
  pcVolume     Int?
  totalVolume  Int?
  sortOrder    Int      @default(0)
  isTracking   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product SmartstoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, keyword])
  @@index([productId])
}

model SmartstoreRankHistory {
  id        String   @id @default(cuid())
  productId String
  keyword   String
  rank      Int?
  pageNum   Int?
  position  Int?
  rankLabel String?
  createdAt DateTime @default(now())

  product SmartstoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, keyword])
}

model SystemConfig {
  id          String   @id
  naverCookie String?
  updatedAt   DateTime @updatedAt
}

/** 블로그 채널 분석 결과 히스토리 (우리 서비스 기준 순위 계산용) */
model BlogAnalysisHistory {
  id                      String    @id @default(cuid())
  userId                  String?
  user                    User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  blogId                  String
  blogName                String?
  nickname                String?
  profileImage            String?   @db.Text
  blogTopic               String?

  visitorCount            Int?
  postCount               Int?
  subscriberCount         Int?
  postingFrequency        Float?

  validKeywordCount       Int?

  level                   Int?
  grade                   String?
  totalScore              Float?
  influenceScore          Float?
  keywordInfluenceScore   Float?
  contentInfluenceScore   Float?

  /** 최근 포스팅 패턴 분석 평균·점수 (저장 시점 스냅샷) */
  averageTitleLength      Float?
  averageContentLength    Float?
  averageImageCount       Float?
  titleLengthScore        Float?
  contentLengthScore      Float?
  imageCountScore         Float?

  totalRank               Int?
  topicRank               Int?

  analyzedAt              DateTime  @default(now())
  createdAt               DateTime  @default(now())

  @@index([blogId])
  @@index([blogTopic])
  @@index([totalScore])
  @@index([analyzedAt])
  @@index([blogTopic, totalScore])
}

/** PostLabs 자체 랭킹용 블로그 최신 프로필 */
model BlogProfile {
  id                 String    @id @default(cuid())
  blogId             String    @unique
  blogUrl            String?   @db.Text
  blogName           String?
  nickname           String?
  profileImage       String?   @db.Text
  officialBlogTopic  String?

  postCount          Int?
  scrapCount         Int?
  neighborCount      Int?
  postingFrequency   Float?
  lastAnalyzedAt     DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([officialBlogTopic])
  @@index([lastAnalyzedAt])
}

/** PostLabs 자체 랭킹 계산용 블로그 단위 메트릭 스냅샷 */
model BlogMetricSnapshot {
  id                       String   @id @default(cuid())
  blogId                   String

  influenceScore           Float?
  keywordInfluenceScore    Float?
  contentInfluenceScore    Float?
  validKeywordCount        Int?
  recentActivityScore      Float?

  avgWordCount             Float?
  avgImageCount            Float?
  avgVideoCount            Float?
  avgCommentCount          Float?
  avgSympathyCount         Float?
  avgShareCount            Float?

  totalScore               Float?
  analyzedAt               DateTime @default(now())
  createdAt                DateTime @default(now())

  @@index([blogId])
  @@index([blogId, analyzedAt])
  @@index([totalScore])
  @@index([analyzedAt])
}

/** PostLabs 자체 랭킹 계산 결과 스냅샷 */
model BlogRankSnapshot {
  id                 String   @id @default(cuid())
  blogId             String
  overallRank        Int?
  topicRank          Int?
  officialBlogTopic  String?
  totalBlogsCount    Int
  topicBlogsCount    Int?
  rankSource         String   @default("postlabs")
  calculatedAt       DateTime @default(now())
  createdAt          DateTime @default(now())

  @@index([blogId])
  @@index([blogId, calculatedAt])
  @@index([overallRank])
  @@index([officialBlogTopic, topicRank])
  @@index([rankSource, calculatedAt])
}

/** PostLabs 자체 랭킹 확장을 위한 블로그 후보 수집 큐 */
model BlogDiscoveryQueue {
  id                 String    @id @default(cuid())
  blogId             String    @unique
  blogUrl            String?   @db.Text
  source             String
  seedKeyword        String?
  officialBlogTopic  String?
  status             String    @default("pending")
  priority           Int       @default(50)
  discoveredAt       DateTime  @default(now())
  lastTriedAt        DateTime?
  analyzedAt         DateTime?
  errorMessage       String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([priority])
  @@index([source])
  @@index([seedKeyword])
  @@index([officialBlogTopic])
  @@index([lastTriedAt])
}

/** 블로그 최근 포스팅별 분석 메트릭 캐시 */
model BlogPostMetricSnapshot {
  id                 String    @id @default(cuid())
  blogId             String
  postKey            String
  postUrl            String    @db.Text
  orgUrl             String?   @db.Text
  logNo              String?
  title              String
  publishedAt        DateTime?
  thumbnail          String?   @db.Text

  wordCount          Int?
  imageCount         Int?
  videoCount         Int?
  commentCount       Int?
  sympathyCount      Int?
  shareCount         Int?

  titleScore         Float?
  contentLengthScore Float?
  imageScore         Float?
  potentialScore     Float?
  reactivityScore    Float?
  relatednessScore   Float?
  postLevel          Int?
  exposureStatus     String?
  foundOnSearch      Boolean?

  analyzedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([blogId, postKey])
  @@index([blogId])
  @@index([blogId, publishedAt])
  @@index([blogId, analyzedAt])
  @@index([exposureStatus])
}

/** 블로그별 실제 검색 노출 기반 유효 키워드 캐시 */
model BlogKeywordExposureSnapshot {
  id                    String   @id @default(cuid())
  blogId                String
  keyword               String

  /** valid | rank_only | volume_only | out_of_rank | low_volume | unchecked — 블로그 노출·검색량 확정 여부 */
  keywordValidationStatus String?

  exposureType          String?
  integratedSearchRank  Int?
  integratedSearchBlock String?
  smartBlockCount       Int?
  blogRank              Int?

  monthlySearchVolume   Int?
  mobileSearchVolume    Int?
  pcSearchVolume        Int?
  contentSaturation     Float?

  sourcePostUrl         String?  @db.Text
  sourcePostTitle       String?
  checkedAt             DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([blogId, keyword])
  @@index([blogId])
  @@index([blogId, checkedAt])
  @@index([exposureType])
  @@index([blogRank])
  @@index([monthlySearchVolume])
}

/**
 * SearchAD 키워드 검색량 영속 캐시 (/top-blog·플레이스·keyword-refresh 등 공통).
 * normalizedKeyword 기준 14일 TTL.
 */
model KeywordSearchVolumeCache {
  id                   String   @id @default(cuid())
  keyword              String   @db.VarChar(512)
  normalizedKeyword    String   @unique @db.VarChar(512)
  monthlyPcQcCnt       Int?
  monthlyMobileQcCnt   Int?
  totalVolume          Int
  /** 월간 합계 기준 250 미만(또는 미발견 0건)으로 확정된 경우 SearchAD 재조회 생략에 사용 */
  belowThreshold       Boolean  @default(false)
  source               String   @default("naver-searchad")
  checkedAt            DateTime @default(now())
  raw                  Json?

  @@index([checkedAt])
}

/** 블로그 분석 저장 목록: 고정/자동추적 상태 영구 저장 */
model BlogAnalysisSaved {
  id           String   @id @default(cuid())
  userId       String?
  blogId       String
  nickname     String?
  blogName     String?
  profileImage String?  @db.Text
  blogTopic    String?
  isPinned     Boolean  @default(false)
  autoTracking Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([blogId])
  @@index([userId])
  @@index([isPinned])
  @@index([autoTracking])
}

model Post {
  id        String   @id @default(cuid())
  category  String
  title     String
  content   String   @db.Text
  isSecret  Boolean  @default(false) // 🚨 비밀글 여부 저장 컬럼 추가! (기본값은 일반글)
  author    User     @relation(fields: [userId], references: [id])
  userId    String
  views     Int      @default(0)
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

comments  Comment[]

  @@index([userId])
}

// (기존 코드들 아래에 추가)

model Track {
  id        String   @id @default(cuid())
  keyword   String
  placeUrl  String
  createdAt DateTime @default(now())
  records   Record[]
}

model Record {
  id        String   @id @default(cuid())
  rank      Int
  createdAt DateTime @default(now())
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id])
}

// 🚨 파일 맨 아래에 통째로 추가해 주세요!
model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  postId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}
