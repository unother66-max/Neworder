generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id     String  @id @default(cuid())
  email  String  @unique
  name   String?
  places Place[]
}

model Track {
  id        String   @id @default(cuid())
  keyword   String
  placeUrl  String
  createdAt DateTime @default(now())
  records   Record[]
}

model Record {
  id        String   @id @default(cuid())
  rank      Int
  createdAt DateTime @default(now())
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id])
}

model Place {
  id                 String               @id @default(cuid())
  userId             String
  name               String
  category           String?
  address            String?
  placeUrl           String?
  imageUrl           String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  jibunAddress       String?
  reviewAutoTracking Boolean              @default(false)
  x                  String?
  y                  String?
  type               String               @default("rank")
  reviewPinned       Boolean              @default(false)
  rankPinned           Boolean              @default(false)
  rankPinnedAt         DateTime?
  kakaoAutoTracking    Boolean              @default(false)
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords           PlaceKeyword[]
  reviewHistory      PlaceReviewHistory[]
  rankHistory        RankHistory[]
  kakaoRankHistory   KakaoRankHistory[]
placeMonthlyVolume Int? @default(0)
placeMobileVolume  Int? @default(0)
placePcVolume      Int? @default(0)


  @@index([userId])
}

model PlaceKeyword {
  id           String   @id @default(cuid())
  placeId      String
  keyword      String
  mobileVolume Int?
  pcVolume     Int?
  totalVolume  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isTracking   Boolean  @default(false)
  place        Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, keyword])
  @@index([placeId])
}

model RankHistory {
  id        String   @id @default(cuid())
  placeId   String
  keyword   String
  rank      Int
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model KakaoRankHistory {
  id           String   @id @default(cuid())
  placeId      String
  keyword      String
  searchAll    Int?
  searchCat    Int?
  directionAll Int?
  directionCat Int?
  favoriteAll  Int?
  favoriteCat  Int?
  shareAll     Int?
  shareCat     Int?
  trackedAt    DateTime @default(now())
  place        Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model PlaceReviewHistory {
  id                 String   @id @default(cuid())
  placeId            String
  trackedDate        String
  totalReviewCount   Int
  visitorReviewCount Int
  blogReviewCount    Int
  saveCount          String
  keywords           String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  place              Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, trackedDate])
  @@index([placeId])
  @@index([trackedDate])
}
