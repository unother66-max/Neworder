generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 공통 설정 ---
enum SmartstoreSpace {
  NAVER_PRICE
  PLUS_STORE
}

enum UserTier {
  FREE
  PRO
}

// --- 🚨 사용자 모델 (인증 및 관계 설정) ---
model User {
  id                      String                   @id @default(cuid())
  email                   String?                  @unique
  name                    String?
  image                   String?
  tier                    UserTier                 @default(FREE)
  emailVerified           DateTime?
  
  // 인증 관련 연결
  accounts                Account[]
  sessions                Session[]
  
  // 기존 기능 연결 (이 모델들이 아래에 정의되어 있어야 에러가 안 납니다)
  places                  Place[]
  smartstoreProducts      SmartstoreProduct[]
  smartstoreReviewTargets SmartstoreReviewTarget[]
  posts                   Post[]
}

// --- 🚨 인증 필수 모델 ---
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?
refresh_token_expires_in Int?


  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- 🚨 기존 기능 모델 (오류 방지를 위해 모두 포함) ---

model Place {
  id                 String               @id @default(cuid())
  userId             String
  name               String
  category           String?
  address            String?
  placeUrl           String?
  imageUrl           String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  jibunAddress       String?
  reviewAutoTracking Boolean              @default(false)
  x                  String?
  y                  String?
  type               String               @default("rank")
  reviewPinned       Boolean              @default(false)
  rankPinned         Boolean              @default(false)
  rankPinnedAt       DateTime?
  kakaoAutoTracking  Boolean              @default(false)
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords           PlaceKeyword[]
  reviewHistory      PlaceReviewHistory[]
  rankHistory        RankHistory[]
  kakaoRankHistory   KakaoRankHistory[]
  placeMonthlyVolume Int?                 @default(0)
  placeMobileVolume  Int?                 @default(0)
  placePcVolume      Int?                 @default(0)

  @@index([userId])
}

model PlaceKeyword {
  id           String   @id @default(cuid())
  placeId      String
  keyword      String
  mobileVolume Int?
  pcVolume     Int?
  totalVolume  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isTracking   Boolean  @default(false)
  place        Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, keyword])
  @@index([placeId])
}

model RankHistory {
  id        String   @id @default(cuid())
  placeId   String
  keyword   String
  rank      Int
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model KakaoRankHistory {
  id           String   @id @default(cuid())
  placeId      String
  keyword      String
  searchAll    Int?
  searchCat    Int?
  directionAll Int?
  directionCat Int?
  favoriteAll  Int?
  favoriteCat  Int?
  shareAll     Int?
  shareCat     Int?
  trackedAt    DateTime @default(now())
  place        Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model PlaceReviewHistory {
  id                 String   @id @default(cuid())
  placeId            String
  trackedDate        String
  totalReviewCount   Int
  visitorReviewCount Int
  blogReviewCount    Int
  saveCount          String
  keywords           String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  place              Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, trackedDate])
  @@index([placeId])
  @@index([trackedDate])
}

model SmartstoreProduct {
  id            String          @id @default(cuid())
  userId        String
  productId     String
  space         SmartstoreSpace @default(NAVER_PRICE)
  productUrl    String
  name          String
  category      String?
  thumbnailLink String?
  imageUrl      String?
  mallName      String?
  sellerTags    String[]        @default([])
  rankPinned    Boolean         @default(false)
  rankPinnedAt  DateTime?
  autoTracking  Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords  SmartstoreKeyword[]
  histories SmartstoreRankHistory[]

  @@unique([userId, productId, space])
  @@index([userId])
  @@index([userId, space])
}

model SmartstoreReviewTarget {
  id                    String   @id @default(cuid())
  userId                String
  productId             String
  productUrl            String
  name                  String
  imageUrl              String?
  storeName             String?
  reviewCount           Int?     @default(0)
  reviewRating          Float?
  reviewPhotoVideoCount Int?     @default(0)
  reviewMonthlyUseCount Int?     @default(0)
  reviewRepurchaseCount Int?     @default(0)
  reviewStorePickCount  Int?     @default(0)
  reviewStarSummary     Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  histories     SmartstoreReviewHistory[]
  recentReviews SmartstoreRecentReview[]

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model SmartstoreReviewHistory {
  id                    String   @id @default(cuid())
  targetId              String
  trackedDate           String
  reviewCount           Int
  reviewRating          Float?
  reviewPhotoVideoCount Int?
  reviewMonthlyUseCount Int?
  reviewRepurchaseCount Int?
  reviewStorePickCount  Int?
  reviewStarSummary     Json?
  createdAt             DateTime @default(now())

  target SmartstoreReviewTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([targetId, trackedDate])
  @@index([targetId])
  @@index([trackedDate])
}

model SmartstoreRecentReview {
  id        String    @id @default(cuid())
  targetId  String
  reviewKey String
  postedAt  DateTime?
  rating    Int?
  author    String?
  content   String
  createdAt DateTime  @default(now())

  target SmartstoreReviewTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([targetId, reviewKey])
  @@index([targetId])
  @@index([createdAt])
}

model SmartstoreKeyword {
  id           String   @id @default(cuid())
  productId    String
  keyword      String
  mobileVolume Int?
  pcVolume     Int?
  totalVolume  Int?
  sortOrder    Int      @default(0)
  isTracking   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product SmartstoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, keyword])
  @@index([productId])
}

model SmartstoreRankHistory {
  id        String   @id @default(cuid())
  productId String
  keyword   String
  rank      Int?
  pageNum   Int?
  position  Int?
  rankLabel String?
  createdAt DateTime @default(now())

  product SmartstoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, keyword])
}

model SystemConfig {
  id          String   @id
  naverCookie String?
  updatedAt   DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  category  String
  title     String
  content   String   @db.Text
  author    User     @relation(fields: [userId], references: [id])
  userId    String
  views     Int      @default(0)
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// (기존 코드들 아래에 추가)

model Track {
  id        String   @id @default(cuid())
  keyword   String
  placeUrl  String
  createdAt DateTime @default(now())
  records   Record[]
}

model Record {
  id        String   @id @default(cuid())
  rank      Int
  createdAt DateTime @default(now())
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id])
}