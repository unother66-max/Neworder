+async function fetchLeadingSearchAdCount(
+  keyword: string,
+  baseHeaders: Record<string, string>
+): Promise<LeadingSearchAdResult> {
+  const url = new URL(NAVER_SEARCH_AD_URL);
+  url.searchParams.set("where", "ad");
+  url.searchParams.set("query", keyword);
+
+  const requestUrl = url.toString();
+  const res = await fetch(requestUrl, {
+    headers: {
+      ...baseHeaders,
+      Accept: "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
+      Referer: `https://search.shopping.naver.com/ns/search?query=${encodeURIComponent(keyword)}`,
+    },
+    cache: "no-store",
+  });
+  const rawText = await res.text();
+  const responsePreview = rawText.slice(0, 220);
+
+  if (!res.ok) {
+    throw new NaverShoppingNextDataHttpError(
+      `Naver Search Ad Error: ${res.status}`,
+      res.status,
+      requestUrl,
+      responsePreview
+    );
+  }
+
+  return {
